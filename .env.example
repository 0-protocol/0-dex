# Runtime chain configuration
ZERO_DEX_CHAIN_ID=1
ZERO_DEX_RPC_URL=https://eth.llamarpc.com
ZERO_DEX_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000

# API protection (optional but recommended)
ZERO_DEX_API_KEY=replace-with-random-string

# Relayer keys
# For production use KMS/HSM or remote signer. Do not store raw keys in plaintext env.
ZERO_DEX_RELAYER_KEY=
ZERO_DEX_RELAYER_ADDRESS=
