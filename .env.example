# Runtime chain configuration
# Required in all environments.
ZERO_DEX_CHAIN_ID=1
ZERO_DEX_RPC_URL=https://eth.llamarpc.com
ZERO_DEX_ESCROW_ADDRESS=0xYourEscrowAddress

# Runtime ports / networking
ZERO_DEX_HTTP_PORT=8080
ZERO_DEX_P2P_LISTEN_ADDR=/ip4/0.0.0.0/tcp/7000
# Comma-separated multiaddrs, example:
# ZERO_DEX_BOOTSTRAP_PEERS=/dns4/node1.example.com/tcp/7000/p2p/12D3KooW...
ZERO_DEX_BOOTSTRAP_PEERS=
ZERO_DEX_P2P_KEY_FILE=.zero-dex/p2p_identity.key
ZERO_DEX_MAX_GOSSIP_BYTES=49152

# API protection (optional but recommended)
ZERO_DEX_API_KEY=replace-with-random-string

# Relayer keys
# For production use KMS/HSM or remote signer. Do not store raw keys in plaintext env.
ZERO_DEX_RELAYER_KEY=
ZERO_DEX_RELAYER_ADDRESS=

# Safety switch: keep false for production.
ZERO_DEX_ALLOW_SIMULATION=false
